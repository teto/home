{
	"$schema":     "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
	"workspace": {
		"useGitIgnore": true,
        "library": [
          "/home/teto/home/contrib/jjui-types.lua"
        ],
		"ignoreDir": [
			"config/wireshark",
			"config/mpv"
		]
	},
    "diagnostics.severity": {
      "redefined-local": "warning"
    },
  "diagnostics": {
    "disable": [
     "need-check-nil"
    ],
     "globals": [
      "ya",
                    "vim",
                    "describe",
                    "it",
                    "before_each",
                    "after_each",
                    "pending",
                    "teardown"

     ]
   }
}
